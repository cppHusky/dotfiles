{
	"$schema":"https://opencode.ai/config.json",
	"autoupdate":false,
	"default_agent": "plan",
	"permission":{
		"bash":{
			"*":"allow",
			"git *":"ask",
			"git diff *":"allow",
			"git log *":"allow",
			"git show *":"allow",
			"git ls-files *":"allow",
			"git ls-remote *":"allow",
			"git status *":"allow",
			"git rev-parse *":"allow"
		},
		"edit":{
			".git/*":"deny",
			"opencode.json":"deny"
		},
		"external_directory":{
			"*":"ask",
			"/tmp/**":"allow"
		},
		"glob":"allow",
		"grep":"allow",
		"list":"allow",
		"question":"allow",
		"read":{
			"*":"allow",
			"*.dev.vars":"deny",
			"*.env":"deny",
			"*.env.*":"deny",
			"*.secret":"deny"
		},
		"skill":"ask",
		"webfetch":"allow",
		"websearch":"allow"
	},
	"plugin":[
		"opencode-wakatime"
	]
}
