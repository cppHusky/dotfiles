{
	"$schema":"https://opencode.ai/config.json",
	"autoupdate":false,
	"default_agent": "plan",
	"permission":{
		"bash":{
			"*":"allow",
			"git *":"ask",
			"git diff":"allow",
			"git log":"allow",
			"git ls-files":"allow",
			"git status":"allow"
		},
		"edit":{
			".git/*":"deny",
			"opencode.json":"deny"
		},
		"glob":"allow",
		"grep":"allow",
		"list":"allow",
		"question":"allow",
		"read":{
			"*":"allow",
			"*.dev.vars":"deny",
			"*.env":"deny",
			"*.env.*":"deny",
			"*.secret":"deny"
		},
		"skill":"ask",
		"webfetch":"allow",
		"websearch":"allow"
	}
}
